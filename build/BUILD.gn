# libace target
# Clang runtime for iOS (provides ___chkstk_darwin used by MoltenVK).
#
# GN build config forbids calling exec_script() here (whitelist restriction),
# so we resolve the actual clang runtime directory by copying it at build
# time via an action target.
_xcode_dev = get_path_info(get_path_info(get_path_info(get_path_info(get_path_info(ios_device_sdk_path, "dir"), "dir"), "dir"), "dir"), "dir")

# Simulator links must use libclang_rt.iossim.a; device uses libclang_rt.ios.a (see collect_clang_rt_ios_a.sh).
_clang_rt_darwin_kind = "ios"
if (defined(use_ios_simulator) && use_ios_simulator) {
  _clang_rt_darwin_kind = "iossim"
}

action("clang_rt_ios_collect") {
  script = "//build_plugins/config/ios/collect_clang_rt_ios_a.sh"
  inputs = [ "//build_plugins/config/ios/collect_clang_rt_ios_a.sh" ]
  outputs = [ "${target_gen_dir}/libclang_rt.ios.a" ]
  args = [
    _xcode_dev,
    rebase_path("${target_gen_dir}/libclang_rt.ios.a", root_build_dir),
    _clang_rt_darwin_kind,
  ]
}

# Path to copied libclang_rt.ios.a for -force_load (so ___chkstk_darwin is always pulled in after MoltenVK).
_clang_rt_ios_out =
    get_label_info(":clang_rt_ios_collect", "target_gen_dir") +
    "/libclang_rt.ios.a"
_clang_rt_ios_force_load_path = rebase_path(_clang_rt_ios_out, root_build_dir)

ohos_shared_library("arkui_ios") {
  ldflags = [
    "-Wl",
    "-install_name",
    "@rpath/libarkui_ios.framework/libarkui_ios",
    "-Wl,-force_load," + _clang_rt_ios_force_load_path,
    
    # libace_ndk.framework references these symbols via dynamic_lookup at
    # runtime. After ace_static_ndk was extracted into libace_ndk, nothing
    # inside libarkui_ios references them anymore, so -dead_strip drops
    # them despite -exported_symbols_list. -u forces the linker to treat
    # each as undefined-from-outside, keeping them alive through dead_strip
    # so the matching libarkui_ios.txt entries can take effect.
    "-Wl,-u,__ZN4OHOS3Ace14CallbackLoggerC1ERKNSt3__112basic_stringIcNS2_11char_traitsIcEENS2_9allocatorIcEEEEm",
    "-Wl,-u,__ZN4OHOS3Ace14CallbackLoggerD1Ev",
    "-Wl,-u,__ZN4OHOS3Ace2V212FLEX_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V212GRID_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V212LIST_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V213RADIO_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V214CUSTOM_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V214TOGGLE_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V215REFRESH_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V216ARC_LIST_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V216PROGRESS_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V216TEXTAREA_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217CHECK_BOX_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217FLOW_ITEM_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217GRID_ITEM_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217LIST_ITEM_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217TEXTINPUT_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V217WATERFLOW_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V218IMAGE_SPAN_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V218XCOMPONENT_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V219DATE_PICKER_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V219TEXT_PICKER_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V219TIME_PICKER_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V221ARC_LIST_ITEM_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V222ARC_SCROLL_BAR_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V222IMAGE_ANIMATOR_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V222UNDEFINED_NODE_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V223LIST_ITEM_GROUP_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V224CONTAINER_PICKER_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V224CUSTOM_SPAN_NODE_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V224LOADING_PROGRESS_ETS_TAGE",
    "-Wl,-u,__ZN4OHOS3Ace2V226EMBEDDED_COMPONENT_ETS_TAGE",

    # c_utils symbols (Parcel/RWLock/string utils) referenced by libace_ndk
    # via dynamic_lookup. Same dead_strip survival pattern as above.
    "-Wl,-u,__ZN4OHOS10ParcelableC2Ev",
    "-Wl,-u,__ZN4OHOS11GetDirFilesERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEERNS0_6vectorIS6_NS4_IS6_EEEE",
    "-Wl,-u,__ZN4OHOS12IsNumericStrERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEE",
    "-Wl,-u,__ZN4OHOS13IsSameTextStrERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEES8_",
    "-Wl,-u,__ZN4OHOS14ExtractFileExtERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEE",
    "-Wl,-u,__ZN4OHOS14PathToRealPathERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEERS6_",
    "-Wl,-u,__ZN4OHOS5Utils6RWLock10UnLockReadEv",
    "-Wl,-u,__ZN4OHOS5Utils6RWLock11UnLockWriteEv",
    "-Wl,-u,__ZN4OHOS5Utils6RWLock8LockReadEv",
    "-Wl,-u,__ZN4OHOS5Utils6RWLock9LockWriteEv",
    "-Wl,-u,__ZN4OHOS5Utils6RWLockC1Eb",
    "-Wl,-u,__ZN4OHOS6Parcel10ReadStringERNSt3__112basic_stringIcNS1_11char_traitsIcEENS1_9allocatorIcEEEE",
    "-Wl,-u,__ZN4OHOS6Parcel10ReadUint64ERy",
    "-Wl,-u,__ZN4OHOS6Parcel10WriteFloatEf",
    "-Wl,-u,__ZN4OHOS6Parcel10WriteInt32Ei",
    "-Wl,-u,__ZN4OHOS6Parcel11WriteBufferEPKvm",
    "-Wl,-u,__ZN4OHOS6Parcel11WriteStringERKNSt3__112basic_stringIcNS1_11char_traitsIcEENS1_9allocatorIcEEEE",
    "-Wl,-u,__ZN4OHOS6Parcel11WriteUint32Ej",
    "-Wl,-u,__ZN4OHOS6Parcel11WriteUint64Ey",
    "-Wl,-u,__ZN4OHOS6Parcel15SetDataCapacityEm",
    "-Wl,-u,__ZN4OHOS6Parcel16WriteUnpadBufferEPKvm",
    "-Wl,-u,__ZN4OHOS6Parcel9ReadInt32Ev",
    "-Wl,-u,__ZN4OHOS6Parcel9WriteBoolEb",
    "-Wl,-u,__ZN4OHOS6ParcelC1Ev",
    "-Wl,-u,__ZN4OHOS6ParcelD1Ev",
    "-Wl,-u,__ZN4OHOS8LowerStrERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEE",
    "-Wl,-u,__ZN4OHOS8SplitStrERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEES8_RNS0_6vectorIS6_NS4_IS6_EEEEbb",
    "-Wl,-u,__ZN4OHOS8StrToIntERKNSt3__112basic_stringIcNS0_11char_traitsIcEENS0_9allocatorIcEEEERi",
    "-Wl,-u,__ZNK4OHOS6Parcel11GetDataSizeEv",
    "-Wl,-u,__ZNK4OHOS6Parcel15GetDataCapacityEv",
    "-Wl,-u,__ZNK4OHOS6Parcel7GetDataEv",

    # ColorManager symbols referenced by libace_ndk via dynamic_lookup.
    "-Wl,-u,__ZN4OHOS12ColorManager23GetColorSpaceByJSObjectEP10napi_env__P12napi_value__",
    "-Wl,-u,__ZN4OHOS12ColorManager24CreateJsColorSpaceObjectEP10napi_env__RNSt3__110shared_ptrINS0_10ColorSpaceEEE",
  ]

  if (ace_engine_enable_reduce_eh_frame) {
    ldflags += [ "-Wl,-no_compact_unwind" ]
  }

  deps = [
    "$ace_root/build:libace_static_ios",
    "$ace_root/interfaces/inner_api/ace_kit:ace_kit",
    "//foundation/appframework:appframework_napis",
    "//foundation/arkui/ace_engine/frameworks/core/components_ng/pattern/menu:ace_core_components_menu_pattern_ng_ios",
    "//plugins/interfaces/native:ace_plugin_util_inner_ios",
  ]
  if (defined(ark_engine)) {
    deps += [
      "//arkcompiler/runtime_core/libpandabase:libarkbase_static",
      "//arkcompiler/runtime_core/libpandafile:libarkfile_static",
    ]

    if (runtime_mode != "release") {
      deps += [
        # for enable debugger
        "//arkcompiler/toolchain/inspector:ark_debugger_static",
        "//arkcompiler/toolchain/inspector:connectserver_debugger_static",
        "//arkcompiler/toolchain/tooling:libark_ecma_debugger_set",
      ]
    }
  }

  deps +=
      [ "//foundation/appframework/arkui/uicontent:ace_uicontent_interface" ]

  # Link after MoltenVK so ___chkstk_darwin is resolved (static lib order matters).
  deps += [ ":clang_rt_ios_collect" ]

  cflags_cc += [
    "-Wall",
    "-frtti",
  ]

  exported_symbols_list = "libarkui_ios.txt"
  part_name = "arkui-x"
  subsystem_name = "arkui"

  assert(icu_dat_name == "icudt74l",
      "arkui_ios exports are aligned to ICU 74; update libarkui_ios.txt when ICU version changes.")
}

